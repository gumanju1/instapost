<div class="max-w-md mx-auto mb-10 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">

  <!-- Header -->
  <div class="flex items-center gap-3 p-4">
    <% if post.user.photo.attached? %>
      <%= image_tag post.user.photo,
          class: "w-10 h-10 rounded-full object-cover" %>
    <% else %>
      <div class="w-10 h-10 rounded-full bg-gray-300"></div>
    <% end %>

    <div class="font-semibold">
      <%= link_to username(post.user_email), user_path(post.user_id) %>
    </div>
  </div>

  <!-- Post Image -->
  <%= image_tag post.photo,
      class: "w-full object-cover max-h-[600px]" %>

  <!-- Post Body -->
  <div class="p-4">

    <p class="mb-3">
      <%= post.description %>
    </p>

    <p class="text-sm text-gray-500 mb-3">
      Posted on <%= post.created_at.strftime("%B %d, %Y") %>
    </p>

    <%= render partial: "likes", locals: { post: post } %>

    <hr class="my-4">

    <% post.comments.each do |comment| %>

      <div class="mb-3">

        <span class="font-semibold">
          <%= link_to username(comment.user_email), user_path(comment.user_id) %>
        </span>

        <span>
          <%= comment.text %>
        </span>

        <% if comment.user == current_user %>
          <div>
            <%= link_to "Delete",
                post_comment_path(post, comment),
                data: { turbo_method: :delete },
                class: "text-red-600 text-sm" %>
          </div>
        <% end %>

      </div>

    <% end %>

    <%= simple_form_for Comment.new,
        url: post_comments_path(post),
        method: :post do |f| %>

      <%= f.input :text,
          label: false,
          placeholder: "Add a comment..." %>

      <%= f.submit "Post",
          class: "mt-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg px-4 py-2" %>

    <% end %>

    <% if post.user == current_user %>

      <div class="flex gap-2 mt-5">

        <%= link_to "Edit",
            edit_post_path(post),
            class: "bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg" %>

        <%= link_to "Delete",
            post_path(post),
            data: { turbo_method: :delete },
            class: "bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg" %>

      </div>

    <% end %>

  </div>

</div>